---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Lost commit — ingit" description="This path is no longer reachable." noindex>
  <main class="not-found">
    <div class="not-found__graph" aria-hidden="true"><i></i><i></i><i></i></div>
    <p class="eyebrow"><span>404</span> DETACHED HEAD</p>
    <h1>This path is no longer reachable.</h1>
    <p>Good news: unlike a lost commit, the homepage is one click away.</p>
    <a class="button button--primary" href="/">Return to main</a>
  </main>
</BaseLayout>
